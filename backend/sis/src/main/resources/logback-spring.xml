<?xml version="1.0" encoding="UTF-8"?>
<!--
  Logback config: outputs structured JSON log lines.
  Satisfies CLAUDE.md §6.5 — every log line must be a valid JSON object.
  Uses logstash-logback-encoder for JSON formatting.
-->
<configuration>
  <springProfile name="!dev">
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
      <encoder class="net.logstash.logback.encoder.LogstashEncoder">
        <customFields>{"service":"sis"}</customFields>
      </encoder>
    </appender>
  </springProfile>

  <springProfile name="dev">
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
      <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
        <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
      </encoder>
    </appender>
  </springProfile>

  <root level="INFO">
    <appender-ref ref="STDOUT"/>
  </root>

  <logger name="com.smartretail" level="INFO"/>
</configuration>
