# =============================================================================
# SmartRetail SPA — Environment variable reference
# =============================================================================
# Copy this file to:
#   .env.local          → for local overrides (git-ignored, safe for real creds)
#   .env.development    → committed defaults for `npm run dev`
#   .env.production     → committed defaults for `npm run build` (no secrets)
#
# Vite loads order (highest wins): .env.local > .env.[mode].local > .env.[mode] > .env
# =============================================================================

# ── API ───────────────────────────────────────────────────────────────────────

# Base URL for the ARS (Analytics & Reporting Service) Lambda via API Gateway.
# Local dev   : http://localhost:4566/restapis/<api-id>/test/_user_request_
# AWS dev     : https://<api-gw-id>.execute-api.us-east-1.amazonaws.com/dev
# AWS prod    : https://<api-gw-id>.execute-api.us-east-1.amazonaws.com/prod
VITE_API_BASE_URL=http://localhost:4000

# When true, all API calls return local mock data (no backend required).
# Set to false to call VITE_API_BASE_URL instead.
# Default: true — safe fallback if var is absent.
VITE_USE_MOCK_API=true

# ── Auth (Cognito) ────────────────────────────────────────────────────────────

# Internal User Pool — leave blank in local/demo mode to use the mock auth bypass.
# When both vars are set, the app configures Amplify and shows the real login UI.
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_CLIENT_ID=

# ── App ───────────────────────────────────────────────────────────────────────

# Shown in the header env badge and the Settings "About" panel.
# Accepted values: DEV | QA | STAGING | PROD
VITE_APP_ENV=DEV
